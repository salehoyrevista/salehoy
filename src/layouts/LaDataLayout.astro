---
import '../styles/globals.css';

interface Props {
  title: string;
  description?: string;
  mesLabel?: string;
}

const {
  title,
  description = 'La Data — Informe mensual de la quiniela argentina. Análisis estadístico por Tomás Vera.',
  mesLabel = '',
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es-AR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <title>{title} · SaleHoy</title>
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500;1,600&family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <!-- Topbar mínima: sin el header global del sitio -->
    <div class="ld-topbar">
      <a href="/la-sala" class="ld-topbar-logo-link">
        <img
          src="/img/logos/logo-lasala-neon.png"
          alt="La Sala · SaleHoy"
          class="ld-logo-mark"
          style="height:32px;width:auto;display:block;"
        />
      </a>
      <span class="ld-room">La sala · La Data</span>
      <span class="ld-edition">{mesLabel}</span>
    </div>

    <slot />
  </body>
</html>

<style>
  body {
    background: var(--paper-warm);
    color: var(--ink);
    font-family: var(--font-sans);
    min-height: 100vh;
    margin: 0;
    padding: 0;
  }

  .ld-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 28px 12px;
    border-bottom: 1px solid var(--ink-line);
    background: var(--paper-warmer);
    gap: 16px;
    flex-wrap: wrap;
  }

  .ld-topbar-logo-link {
    display: flex;
    align-items: center;
    text-decoration: none;
  }

  .ld-room {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--ink-muted);
    flex: 1;
    text-align: center;
  }

  .ld-edition {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cuero);
  }

  @media (max-width: 820px) {
    .ld-topbar { padding: 14px 20px 10px; gap: 8px; }
    .ld-room { display: none; }
    .ld-logo-mark { height: 28px !important; }
  }
</style>
