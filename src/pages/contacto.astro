---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contacto" description="Para conversar, sumar, sugerir.">
  <article class="inst-page">
    <header class="inst-page__header">
      <span class="meta-label">Contacto</span>
      <h1 class="inst-page__title">Contacto</h1>
      <p class="hero-lead">Para conversar, sumar, sugerir.</p>
    </header>

    <div class="prose">
      <p>Para escribirle al editor:</p>
      <p class="email-display"><a href="mailto:juan@salehoy.com.ar">juan@salehoy.com.ar</a></p>
      <p>Si tenés una anécdota sobre el juego, mejor mandala por el <a href="/anecdotario">Anecdotario</a>.</p>
      <p>Si querés recibir cada edición por mail, <a href="/newsletter">suscribite al newsletter</a>.</p>
    </div>
  </article>
</BaseLayout>

<style>
  .inst-page {
    padding-block: var(--space-3xl);
    max-width: 640px;
    margin-inline: auto;
    padding-inline: var(--gutter-xs);
  }

  .inst-page__header {
    margin-bottom: var(--space-2xl);
  }

  .inst-page__title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--font-semibold);
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
    margin-top: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .prose {
    max-width: none;
  }

  .email-display {
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    letter-spacing: -0.01em;
  }

  .email-display a {
    color: var(--color-accent-gold);
    text-decoration: none;
  }

  .email-display a:hover {
    text-decoration: underline;
    text-underline-offset: 0.2em;
  }
</style>
