---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="La sala"
  description="La sala de SaleHoy: La Vichy, La Data, la Máquina de Frases, el Anecdotario y El Generador. La zona viva de la revista."
>
  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=VT323&family=Press+Start+2P&display=swap" />

  <!-- Marquee strip -->
  <div class="sala-marquee">
    <span class="sala-lights">
      <span class="bulb"></span><span class="bulb"></span><span class="bulb"></span>
      <span class="bulb"></span><span class="bulb"></span><span class="bulb"></span>
    </span>
    <span class="marquee-text">★ LA SALA ★ ZONA VIVA DE SALEHOY ★ ABIERTA HASTA TARDE ★</span>
    <span class="sala-lights">
      <span class="bulb"></span><span class="bulb"></span><span class="bulb"></span>
      <span class="bulb"></span><span class="bulb"></span><span class="bulb"></span>
    </span>
  </div>

  <!-- Breadcrumb -->
  <nav class="sala-breadcrumb" aria-label="Breadcrumb">
    <span class="sala-breadcrumb__star">★</span>La sala
  </nav>

  <!-- Hero -->
  <section class="sala-hero">
    <div class="sala-hero__eyebrow">★ ZONA VIVA ★</div>
    <img
      class="sala-hero__neon"
      src="/img/logos/logo_neon/elegido-neon.jpg"
      alt="SaleHoy al aire — La Sala"
      width="420"
      height="auto"
    />
    <p class="sala-hero__lead">La zona viva de SaleHoy. Pasen, está abierta.</p>
  </section>

  <!-- Device grid -->
  <section class="device-grid" aria-label="Secciones de La Sala">

    <!-- LA VICHY -->
    <a class="card card--vichy" href="/la-vichy">
      <header class="card-marquee">
        <span class="pin"></span><span>★ LA VICHY ★</span><span class="pin"></span>
      </header>
      <div class="card-illo">
        <svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <!-- Mate cup -->
          <path d="M38 80 Q36 55 40 40 L80 40 Q84 55 82 80 Z"/>
          <!-- Rim -->
          <line x1="36" y1="40" x2="84" y2="40"/>
          <!-- Bombilla -->
          <line x1="60" y1="80" x2="72" y2="28" stroke-width="1.8"/>
          <circle cx="73" cy="26" r="4" fill="currentColor" stroke="none"/>
          <!-- Steam -->
          <g class="illo-steam">
            <path d="M50 35 Q47 28 50 22 Q53 16 50 10" stroke-width="1.1" fill="none"/>
            <path d="M60 33 Q57 26 60 20 Q63 14 60 8" stroke-width="1.1" fill="none"/>
            <path d="M70 35 Q67 28 70 22 Q73 16 70 10" stroke-width="1.1" fill="none"/>
          </g>
          <!-- Saucer -->
          <ellipse cx="60" cy="82" rx="28" ry="5"/>
          <!-- Card suits -->
          <text x="44" y="68" font-family="serif" font-size="14" fill="currentColor" stroke="none">♠</text>
          <text x="68" y="68" font-family="serif" font-size="14" fill="currentColor" stroke="none">♦</text>
        </svg>
      </div>
      <h2 class="card-title">El portal de los números</h2>
      <p class="card-desc">Doña de Rosario. Tira las cartas y lee los números. Cocina, mate, radio bajita.</p>
      <div class="card-cta"><span>TOCAR EL TIMBRE</span><span class="arrow">→</span></div>
    </a>

    <!-- LA DATA -->
    <a class="card card--data card--crt" href="/quiniela">
      <header class="card-marquee">
        <span class="pin"></span><span>★ LA DATA ★</span><span class="pin"></span>
      </header>
      <div class="card-illo">
        <svg viewBox="0 0 120 110" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <!-- Chart bars -->
          <line x1="20" y1="90" x2="110" y2="90"/>
          <line x1="20" y1="90" x2="20" y2="15"/>
          <rect class="illo-bar" x="28" y="60" width="12" height="30" fill="currentColor" stroke="none" transform-origin="28 90"/>
          <rect class="illo-bar" x="46" y="45" width="12" height="45" fill="currentColor" stroke="none" transform-origin="46 90"/>
          <rect class="illo-bar" x="64" y="30" width="12" height="60" fill="currentColor" stroke="none" transform-origin="64 90"/>
          <rect class="illo-bar" x="82" y="50" width="12" height="40" fill="currentColor" stroke="none" transform-origin="82 90"/>
          <rect class="illo-bar" x="100" y="38" width="12" height="52" fill="currentColor" stroke="none" transform-origin="100 90"/>
        </svg>
      </div>
      <h2 class="card-title">Informe mensual de la Quiniela</h2>
      <p class="card-desc">Análisis estadístico. Nacional, Buenos Aires, Córdoba. No es soplo.</p>
      <div class="card-cta"><span>VER EL INFORME</span><span class="arrow">→</span></div>
    </a>

    <!-- MÁQUINA DE FRASES -->
    <a class="card card--frases card--crt" href="/maquina-de-frases">
      <header class="card-marquee">
        <span class="pin"></span><span>★ MÁQUINA DE FRASES ★</span><span class="pin"></span>
      </header>
      <div class="card-illo">
        <svg viewBox="0 0 140 110" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="20" y="14" width="80" height="80" rx="3"/>
          <rect x="28" y="28" width="64" height="32" stroke-width="1.1"/>
          <line x1="49" y1="28" x2="49" y2="60"/>
          <line x1="70" y1="28" x2="70" y2="60"/>
          <text x="38" y="50" font-family="serif" font-size="14" fill="currentColor" stroke="none">7</text>
          <text x="56" y="51" font-family="serif" font-size="14" fill="currentColor" stroke="none">★</text>
          <text x="79" y="50" font-family="serif" font-size="14" fill="currentColor" stroke="none">?</text>
          <line x1="40" y1="76" x2="80" y2="76" stroke-width="1.6"/>
          <g class="illo-lever">
            <line x1="100" y1="44" x2="118" y2="22" stroke-width="1.6"/>
            <circle cx="120" cy="20" r="5" fill="currentColor" stroke="none"/>
            <line x1="100" y1="44" x2="100" y2="86" stroke-width="1.1"/>
          </g>
        </svg>
      </div>
      <h2 class="card-title">Tirá la palanca</h2>
      <p class="card-desc">80 frases sobre el juego, el azar y la suerte. Si sale el jackpot, lo sabés.</p>
      <div class="card-cta"><span>TIRAR LA PALANCA</span><span class="arrow">→</span></div>
    </a>

    <!-- ANECDOTARIO -->
    <a class="card card--anec" href="/anecdotario">
      <header class="card-marquee">
        <span class="pin"></span><span>★ ANECDOTARIO ★</span><span class="pin"></span>
      </header>
      <div class="card-illo">
        <svg viewBox="0 0 140 100" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="70" y1="16" x2="70" y2="88" stroke-width="1"/>
          <path d="M70 16 Q 50 12, 16 18 L 16 86 Q 50 82, 70 88"/>
          <line x1="22" y1="32" x2="64" y2="30" stroke-width="0.9"/>
          <line x1="22" y1="42" x2="64" y2="40" stroke-width="0.9"/>
          <line x1="22" y1="52" x2="56" y2="50" stroke-width="0.9"/>
          <line x1="22" y1="62" x2="64" y2="60" stroke-width="0.9"/>
          <line x1="22" y1="72" x2="48" y2="71" stroke-width="0.9"/>
          <g class="illo-page">
            <path d="M70 16 Q 90 12, 124 18 L 124 86 Q 90 82, 70 88"/>
            <line x1="76" y1="32" x2="118" y2="30" stroke-width="0.9"/>
            <line x1="76" y1="42" x2="118" y2="40" stroke-width="0.9"/>
            <text x="84" y="60" font-family="serif" font-size="14" fill="currentColor" stroke="none">17</text>
            <line x1="76" y1="74" x2="118" y2="72" stroke-width="0.9"/>
          </g>
          <circle class="illo-mark" cx="90" cy="55" r="9" stroke-width="1"/>
        </svg>
      </div>
      <h2 class="card-title">Anécdotas reales, jugadores reales</h2>
      <p class="card-desc">La quiniela de tu vieja, el truco de tu abuelo, el 17 que volvió.</p>
      <div class="card-cta"><span>CONTÁ TU ANÉCDOTA</span><span class="arrow">→</span></div>
    </a>

    <!-- EL GENERADOR -->
    <a class="card card--ruleta card--crt" href="/ruleta">
      <header class="card-marquee">
        <span class="pin"></span><span>★ EL GENERADOR ★</span><span class="pin"></span>
      </header>
      <div class="card-illo">
        <svg viewBox="0 0 120 120" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" aria-hidden="true">
          <circle cx="60" cy="60" r="48"/>
          <circle cx="60" cy="60" r="34" stroke-width="1"/>
          <g class="illo-wheel">
            <line x1="60" y1="12" x2="60" y2="108"/>
            <line x1="12" y1="60" x2="108" y2="60"/>
            <line x1="26" y1="26" x2="94" y2="94" stroke-width="1"/>
            <line x1="94" y1="26" x2="26" y2="94" stroke-width="1"/>
            <line x1="18" y1="42" x2="102" y2="78" stroke-width="0.8"/>
            <line x1="42" y1="18" x2="78" y2="102" stroke-width="0.8"/>
            <line x1="102" y1="42" x2="18" y2="78" stroke-width="0.8"/>
            <line x1="78" y1="18" x2="42" y2="102" stroke-width="0.8"/>
          </g>
          <circle cx="60" cy="60" r="6" fill="currentColor" stroke="none"/>
          <g class="illo-ball">
            <circle cx="60" cy="20" r="3" fill="currentColor" stroke="none"/>
          </g>
          <g class="illo-num">
            <text x="60" y="103" text-anchor="middle" font-family="monospace" font-size="11" fill="currentColor" stroke="none">07</text>
            <text x="60" y="103" text-anchor="middle" font-family="monospace" font-size="11" fill="currentColor" stroke="none">22</text>
            <text x="60" y="103" text-anchor="middle" font-family="monospace" font-size="11" fill="currentColor" stroke="none">14</text>
            <text x="60" y="103" text-anchor="middle" font-family="monospace" font-size="11" fill="currentColor" stroke="none">31</text>
          </g>
        </svg>
      </div>
      <h2 class="card-title">El Generador</h2>
      <p class="card-desc">Para los sorteos chicos, los amigos, las apuestas del bar.</p>
      <div class="card-cta"><span>HACER GIRAR</span><span class="arrow">→</span></div>
    </a>

  </section>

  <!-- Sedronar -->
  <div class="sala-sedronar">
    <span class="sala-sedronar__star">★</span>
    <span>La sala es contenido cultural de SaleHoy. <strong>Si jugás y te preocupa cómo jugás, hablá con alguien.</strong> Línea Sedronar 141.</span>
  </div>

</BaseLayout>

<style>
  /* ============================================================
     Variables locales de La Sala — no tocan tokens.css
     ============================================================ */
  .sala-marquee,
  .sala-breadcrumb,
  .sala-hero,
  .device-grid,
  .sala-sedronar {
    --sala-rojo:     var(--color-accent-red);
    --sala-cuero:    var(--color-leather);
    --sala-dorado:   var(--color-accent-gold);
    --sala-ink:      var(--color-text);
    --sala-ink-muted: var(--color-text-secondary);

    /* Fondos por dispositivo — hardcoded, identidad de cada sección */
    --vichy-bg:      #F3E4CE;
    --vichy-accent:  #B7472A;
    --data-bg:       #16243A;
    --data-accent:   #4CDC78;
    --frases-bg:     #6E2125;
    --frases-accent: #C9A96E;
    --anec-bg:       #4A2F1A;
    --anec-accent:   #E5A547;
    --ruleta-bg:     #143524;
    --ruleta-accent: #4CDC78;
  }

  /* ============================================================
     Marquee strip
     ============================================================ */
  .sala-marquee {
    background: #1A1A1A;
    padding: 14px var(--gutter-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 28px;
    border-bottom: 1px solid #000;
  }

  .marquee-text {
    font-family: 'Press Start 2P', monospace;
    font-size: 11px;
    letter-spacing: 0.32em;
    color: var(--sala-dorado);
    text-shadow: 0 0 6px rgba(212, 175, 55, 0.35);
    white-space: nowrap;
  }

  .sala-lights {
    display: flex;
    gap: 14px;
    align-items: center;
  }

  .sala-lights .bulb {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--sala-dorado);
    box-shadow: 0 0 6px rgba(212, 175, 55, 0.6);
    animation: twinkle 1.6s ease-in-out infinite;
  }
  .sala-lights .bulb:nth-child(2) { animation-delay: 0.15s; }
  .sala-lights .bulb:nth-child(3) { animation-delay: 0.30s; }
  .sala-lights .bulb:nth-child(4) { animation-delay: 0.45s; }
  .sala-lights .bulb:nth-child(5) { animation-delay: 0.60s; }
  .sala-lights .bulb:nth-child(6) { animation-delay: 0.75s; }

  @keyframes twinkle {
    0%, 100% { opacity: 0.30; }
    50%       { opacity: 0.85; }
  }

  /* ============================================================
     Breadcrumb
     ============================================================ */
  .sala-breadcrumb {
    max-width: var(--container-wide);
    margin: 0 auto;
    padding: 14px var(--gutter-sm) 6px;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sala-cuero);
  }

  .sala-breadcrumb__star {
    color: var(--sala-rojo);
    margin-right: var(--space-sm);
  }

  /* ============================================================
     Hero
     ============================================================ */
  .sala-hero {
    max-width: var(--container-narrow);
    margin: var(--space-xl) auto var(--space-2xl);
    padding: 0 var(--gutter-sm);
    text-align: center;
  }

  .sala-hero__eyebrow {
    font-family: 'Press Start 2P', monospace;
    font-size: 10px;
    letter-spacing: 0.36em;
    color: var(--sala-rojo);
    margin-bottom: var(--space-md);
  }

  .sala-hero__neon {
    display: block;
    width: 100%;
    max-width: 360px;
    margin: 0 auto var(--space-md);
    mix-blend-mode: multiply;
  }

  [data-theme='dark'] .sala-hero__neon {
    mix-blend-mode: screen;
    opacity: 0.85;
  }

  .sala-hero__lead {
    font-family: var(--font-display);
    font-style: italic;
    font-size: clamp(1.125rem, 1.5vw, 1.375rem);
    line-height: 1.5;
    color: var(--sala-cuero);
    margin: 0 auto;
    max-width: 36ch;
  }

  /* ============================================================
     Device grid
     ============================================================ */
  .device-grid {
    max-width: var(--container-wide);
    margin: 0 auto var(--space-3xl);
    padding: 0 var(--gutter-sm);
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 18px;
  }

  @media (max-width: 1100px) {
    .device-grid {
      grid-template-columns: repeat(3, 1fr);
    }
    .device-grid .card:nth-child(4) { grid-column: 1; }
    .device-grid .card:nth-child(5) { grid-column: 2 / span 2; }
  }

  @media (max-width: 640px) {
    .device-grid {
      grid-template-columns: 1fr;
    }
    .device-grid .card:nth-child(4),
    .device-grid .card:nth-child(5) {
      grid-column: auto;
    }
  }

  /* ============================================================
     Card base
     ============================================================ */
  .card {
    display: flex;
    flex-direction: column;
    min-height: 420px;
    border: 1px solid rgba(26, 26, 26, 0.18);
    position: relative;
    overflow: hidden;
    cursor: pointer;
    transition: transform 200ms ease, border-color 120ms;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-sm);
  }

  .card:hover {
    transform: translateY(-2px);
    border-color: rgba(26, 26, 26, 0.5);
  }

  /* Card marquee (top strip) */
  .card-marquee {
    background: #1A1A1A;
    padding: 9px 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    font-family: 'Press Start 2P', monospace;
    font-size: 8px;
    letter-spacing: 0.18em;
    border-bottom: 1px solid rgba(0, 0, 0, 0.4);
  }

  .pin {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: currentColor;
    opacity: 0.6;
    animation: twinkle 2s ease-in-out infinite;
  }
  .pin:nth-child(3) { animation-delay: 0.4s; }
  .pin:nth-child(4) { animation-delay: 0.8s; }

  .card-illo {
    flex: 0 0 auto;
    padding: 28px 24px 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 150px;
  }

  .card-illo svg {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 130px;
  }

  .card-title {
    font-family: var(--font-display);
    font-weight: var(--font-semibold);
    font-size: var(--text-xl);
    line-height: 1.12;
    letter-spacing: -0.005em;
    margin: var(--space-xs) var(--space-lg) var(--space-sm);
    text-wrap: balance;
  }

  .card-desc {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-sm);
    line-height: 1.5;
    margin: 0 var(--space-lg) var(--space-lg);
    text-wrap: pretty;
  }

  .card-cta {
    margin-top: auto;
    padding: var(--space-md) var(--space-lg);
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    font-family: 'Press Start 2P', monospace;
    font-size: 8px;
    letter-spacing: 0.20em;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .arrow {
    font-family: var(--font-body);
    font-size: var(--text-lg);
  }

  /* CRT scanlines overlay */
  .card--crt::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      to bottom,
      transparent 0,
      transparent 2px,
      rgba(0, 0, 0, 0.10) 2px,
      rgba(0, 0, 0, 0.10) 3px
    );
    pointer-events: none;
    mix-blend-mode: multiply;
  }

  /* ============================================================
     Per-device card paint
     ============================================================ */

  /* La Vichy — crema cálida + terracota */
  .card--vichy {
    background: var(--vichy-bg);
    color: #1A1A1A;
    border-color: rgba(183, 71, 42, 0.25);
  }
  .card--vichy .card-marquee { color: var(--vichy-accent); }
  .card--vichy .card-illo svg { color: var(--vichy-accent); }
  .card--vichy .card-title { color: #1A1A1A; }
  .card--vichy .card-desc  { color: #5A4030; }
  .card--vichy .card-cta {
    background: var(--vichy-accent);
    color: #FAF3E2;
    border-top-color: rgba(0, 0, 0, 0.15);
  }

  /* La Data — azul profundo + verde fosforescente */
  .card--data { background: var(--data-bg); color: #F4ECDC; }
  .card--data .card-marquee { color: var(--data-accent); }
  .card--data .card-illo svg { color: var(--data-accent); }
  .card--data .card-title  { color: #F4ECDC; }
  .card--data .card-desc   { color: rgba(244, 236, 220, 0.7); }
  .card--data .card-cta    { color: var(--data-accent); text-shadow: 0 0 8px rgba(76, 220, 120, 0.4); }

  /* Máquina de Frases — rojo profundo + dorado */
  .card--frases { background: var(--frases-bg); color: #F4ECDC; }
  .card--frases .card-marquee { color: var(--frases-accent); }
  .card--frases .card-illo svg { color: var(--frases-accent); }
  .card--frases .card-title { color: #F4ECDC; }
  .card--frases .card-desc  { color: rgba(244, 236, 220, 0.75); }
  .card--frases .card-cta   { color: var(--frases-accent); text-shadow: 0 0 6px rgba(201, 169, 110, 0.3); }

  /* Anecdotario — marrón cálido + ámbar */
  .card--anec { background: var(--anec-bg); color: #F4ECDC; }
  .card--anec .card-marquee { color: var(--anec-accent); }
  .card--anec .card-illo svg { color: var(--anec-accent); }
  .card--anec .card-title { color: #F4ECDC; }
  .card--anec .card-desc  { color: rgba(244, 236, 220, 0.75); }
  .card--anec .card-cta   { color: var(--anec-accent); }

  /* El Generador — verde oscuro CRT + verde fosforescente */
  .card--ruleta { background: var(--ruleta-bg); color: #F4ECDC; }
  .card--ruleta .card-marquee { color: var(--ruleta-accent); }
  .card--ruleta .card-illo svg { color: var(--ruleta-accent); }
  .card--ruleta .card-title { color: #F4ECDC; }
  .card--ruleta .card-desc  { color: rgba(244, 236, 220, 0.7); }
  .card--ruleta .card-cta   { color: var(--ruleta-accent); text-shadow: 0 0 8px rgba(76, 220, 120, 0.4); }

  /* ============================================================
     Ilustraciones — animaciones
     ============================================================ */

  /* Vichy — humo del mate */
  .illo-steam path {
    animation: sh-steam 3.6s ease-in-out infinite;
    transform-box: view-box;
  }
  .illo-steam path:nth-of-type(2) { animation-delay: 1.2s; }
  .illo-steam path:nth-of-type(3) { animation-delay: 2.0s; }
  @keyframes sh-steam {
    0%   { opacity: 0;    transform: translateY(8px); }
    28%  { opacity: 0.85; }
    100% { opacity: 0;    transform: translateY(-12px); }
  }

  /* La Data — barras */
  .illo-bar {
    animation: sh-grow 2.6s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: bottom;
  }
