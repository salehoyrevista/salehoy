    color: #ffd700;
    text-shadow: 0 0 6px #ffd700;
    animation: confetti 1.4s ease-out var(--delay) forwards;
  }
  @keyframes confetti {
    0% {
      transform: translate(0, 0) rotate(0deg) scale(0.3);
      opacity: 1;
    }
    100% {
      transform: translate(
        calc((var(--i) - 15) * 28px),
        calc(-140px - (var(--i) * 3px))
      ) rotate(720deg) scale(0.9);
      opacity: 0;
    }
  }

