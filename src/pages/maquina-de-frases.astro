---
import BaseLayout from '../layouts/BaseLayout.astro';
import { FRASES } from '../data/frases.ts';

const frasesPool = FRASES.map(f => ({
  id: f.id,
  texto: f.texto,
  autor: f.autor,
  obra: f.obra ?? '',
  categoria: f.categoria,
}));
---

<BaseLayout
  title="Máquina de Frases"
  description="Tirá la palanca y descubrí frases sobre el azar, el juego y la suerte. Borges, Discépolo, refranes, Pascal, Maradona."
>
  <link slot="head" rel="preconnect" href="https://fonts.googleapis.com" />
  <link slot="head" rel="stylesheet" href="https://fonts.googleapis.com/css2?family=VT323&family=Press+Start+2P&display=swap" />

  <section class="page container-narrow">
    <nav class="mf-crumbs" aria-label="Migas de pan">
      <a href="/la-sala" class="mf-crumb">★ LA SALA</a>
      <span class="mf-crumb-sep">›</span>
      <span class="mf-crumb mf-crumb--current">MÁQUINA DE FRASES</span>
    </nav>
    <p class="mf-intro">
      Tirá la palanca y descubrí una cita sobre el azar, la suerte, el juego o el destino.
    </p>

    <!-- ===================================================== -->
    <!-- SINTONIZADOR DE CATEGORÍAS                            -->
    <!-- ===================================================== -->
    <div class="tuner" id="tuner" role="group" aria-label="Filtrar por categoría"></div>

    <!-- ===================================================== -->
    <!-- MÁQUINA                                               -->
    <!-- ===================================================== -->
    <div class="machine-wrap">
      <div class="machine" id="machine">

        <!-- MARQUESINA -->
        <div class="marquee">
          <div class="bulbs">
            {Array.from({length: 11}).map((_, i) => (
              <span class="bulb" style={`animation-delay:${i * 0.13}s`}></span>
            ))}
          </div>
          <div class="title-plate">
            <span class="title-mark">★</span>
            <span class="title-text">MÁQUINA DE FRASES</span>
            <span class="title-mark">★</span>
          </div>
          <div class="subtitle">SALEHOY · SINCE 2026</div>
        </div>

        <!-- CUERPO -->
        <div class="body">
          <!-- LEDs panel -->
          <div class="led-strip">
            <span class="led led--green"><b>●</b><span>PWR</span></span>
            <span class="led led--amber"><b>●</b><span>READY</span></span>
            <span class="led led--cyan" id="led-auto"><b>●</b><span>AUTO</span></span>
          </div>

          <!-- CRT -->
          <div class="tv">
            <div class="tv__bezel">
              <div class="tv__screen" id="screen">
                <div class="tv__content" id="display" aria-live="polite">
                  <div class="boot">
                    <p>&gt; SALEHOY · MÁQUINA DE FRASES v2.0</p>
                    <p>&gt; SYSTEM READY_</p>
                    <p class="boot__hint">[ TIRÁ LA PALANCA → ]</p>
                  </div>
                </div>
                <div class="tv__scanlines"></div>
                <div class="tv__glow"></div>
                <div class="tv__flicker"></div>
              </div>
              <span class="screw screw--tl"></span>
              <span class="screw screw--tr"></span>
              <span class="screw screw--bl"></span>
              <span class="screw screw--br"></span>
            </div>
            <div class="tv__brand">★ SALEHOY ★ ALL-PURPOSE QUOTE MACHINE</div>
          </div>

          <!-- Panel de control -->
          <div class="control-panel">
            <!-- AUTO + velocidad -->
            <div class="auto-cluster">
              <button id="btn-auto" class="ctrl-btn ctrl-btn--auto" title="Modo AUTO (A)">AUTO</button>
              <div class="speed-selector" id="speed-selector">
                <button class="speed-btn" data-speed="20000">LENTO</button>
                <button class="speed-btn speed-btn--active" data-speed="12000">MEDIO</button>
                <button class="speed-btn" data-speed="7000">RÁPIDO</button>
              </div>
            </div>
            <!-- Fullscreen -->
            <button id="btn-fs" class="ctrl-btn ctrl-btn--icon" title="Pantalla completa (F)" aria-label="Pantalla completa">
              <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
                <path d="M1 1h5v2H3v3H1V1zm9 0h5v5h-2V3h-3V1zM1 10h2v3h3v2H1v-5zm12 3h-3v2h5v-5h-2v3z"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- BASE -->
        <div class="base">
          <div class="bulbs bulbs--small">
            {Array.from({length: 9}).map((_, i) => (
              <span class="bulb bulb--small" style={`animation-delay:${i * 0.18}s`}></span>
            ))}
          </div>
        </div>

        <!-- PALANCA -->
        <button id="lever" class="lever" aria-label="Tirar la palanca (Espacio)">
          <svg class="lever__svg" viewBox="0 0 240 360" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <defs>
              <linearGradient id="chromeShaft" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#1a1d24"/>
                <stop offset="12%" stop-color="#6a7280"/>
                <stop offset="38%" stop-color="#f5f7fa"/>
                <stop offset="52%" stop-color="#e8ecf2"/>
                <stop offset="72%" stop-color="#8a92a0"/>
                <stop offset="100%" stop-color="#0a0d14"/>
              </linearGradient>
              <linearGradient id="chromeCollar" x1="0" y1="0" x2="1" y2="0">
                <stop offset="0%" stop-color="#0a0d14"/>
                <stop offset="20%" stop-color="#7a8290"/>
                <stop offset="45%" stop-color="#ffffff"/>
                <stop offset="55%" stop-color="#f0f3f8"/>
                <stop offset="80%" stop-color="#5a6068"/>
                <stop offset="100%" stop-color="#0a0d14"/>
              </linearGradient>
              <radialGradient id="ballGrad" cx="0.3" cy="0.25" r="0.95">
                <stop offset="0%" stop-color="#ffb0b0"/>
                <stop offset="18%" stop-color="#ee5050"/>
                <stop offset="55%" stop-color="#a40d20"/>
                <stop offset="90%" stop-color="#5a0510"/>
                <stop offset="100%" stop-color="#2a0008"/>
              </radialGradient>
              <radialGradient id="ballHighlight" cx="0.5" cy="0.5" r="0.5">
                <stop offset="0%" stop-color="rgba(255,255,255,0.9)"/>
                <stop offset="60%" stop-color="rgba(255,255,255,0.2)"/>
                <stop offset="100%" stop-color="rgba(255,255,255,0)"/>
              </radialGradient>
              <radialGradient id="plateGrad" cx="0.35" cy="0.3" r="0.85">
                <stop offset="0%" stop-color="#d4d8e0"/>
                <stop offset="30%" stop-color="#7a8290"/>
                <stop offset="65%" stop-color="#2a2f3a"/>
                <stop offset="100%" stop-color="#050709"/>
              </radialGradient>
              <radialGradient id="plateHole" cx="0.5" cy="0.4" r="0.7">
                <stop offset="0%" stop-color="#000000"/>
                <stop offset="65%" stop-color="#050609"/>
                <stop offset="100%" stop-color="#1a1d24"/>
              </radialGradient>
              <radialGradient id="screwGold" cx="0.3" cy="0.3" r="0.7">
                <stop offset="0%" stop-color="#ffe8a8"/>
                <stop offset="40%" stop-color="#d4af37"/>
                <stop offset="100%" stop-color="#6a4a10"/>
              </radialGradient>
              <filter id="armShadow" x="-50%" y="-50%" width="200%" height="200%">
                <feDropShadow dx="3" dy="6" stdDeviation="5" flood-color="#000" flood-opacity="0.55"/>
              </filter>
            </defs>
            <g class="lever__plate">
              <ellipse cx="50" cy="270" rx="56" ry="14" fill="rgba(0,0,0,0.6)" opacity="0.55"/>
              <ellipse cx="50" cy="260" rx="52" ry="62" fill="url(#plateGrad)"/>
              <ellipse cx="50" cy="260" rx="52" ry="62" fill="none" stroke="#d4af37" stroke-width="1.2" opacity="0.55"/>
              <ellipse cx="42" cy="220" rx="32" ry="10" fill="rgba(255,255,255,0.15)"/>
              <g class="lever__screws">
                <circle cx="18" cy="222" r="4.5" fill="url(#screwGold)"/>
                <line x1="14.5" y1="222" x2="21.5" y2="222" stroke="#3a2510" stroke-width="1.2" stroke-linecap="round"/>
                <circle cx="18" cy="298" r="4.5" fill="url(#screwGold)"/>
                <line x1="15" y1="295" x2="21" y2="301" stroke="#3a2510" stroke-width="1.2" stroke-linecap="round"/>
                <circle cx="82" cy="222" r="4.5" fill="url(#screwGold)"/>
                <line x1="79" y1="219" x2="85" y2="225" stroke="#3a2510" stroke-width="1.2" stroke-linecap="round"/>
                <circle cx="82" cy="298" r="4.5" fill="url(#screwGold)"/>
                <line x1="78.5" y1="298" x2="85.5" y2="298" stroke="#3a2510" stroke-width="1.2" stroke-linecap="round"/>
              </g>
              <ellipse cx="50" cy="260" rx="24" ry="30" fill="url(#plateHole)"/>
              <ellipse cx="50" cy="248" rx="18" ry="5" fill="rgba(255,255,255,0.1)"/>
              <text x="50" y="288" text-anchor="middle" fill="#d4af37" opacity="0.6" font-family="'Press Start 2P', monospace" font-size="6" letter-spacing="1">PULL</text>
            </g>
            <g class="lever__arm" filter="url(#armShadow)">
              <ellipse cx="50" cy="260" rx="20" ry="16" fill="url(#chromeCollar)"/>
              <ellipse cx="50" cy="254" rx="14" ry="4" fill="rgba(255,255,255,0.55)"/>
              <rect x="40" y="55" width="20" height="210" rx="5" fill="url(#chromeShaft)"/>
              <rect x="48" y="55" width="2" height="210" fill="rgba(255,255,255,0.4)"/>
              <rect x="34" y="150" width="32" height="11" rx="3" fill="url(#chromeCollar)"/>
              <rect x="34" y="159" width="32" height="2" fill="rgba(0,0,0,0.4)"/>
              <rect x="36" y="95" width="28" height="6" rx="2" fill="url(#chromeCollar)"/>
              <circle cx="50" cy="40" r="32" fill="url(#ballGrad)" stroke="#1a0308" stroke-width="1.5"/>
              <ellipse cx="38" cy="28" rx="13" ry="10" fill="url(#ballHighlight)"/>
              <circle cx="40" cy="28" r="3.5" fill="rgba(255,255,255,0.95)"/>
              <ellipse cx="56" cy="58" rx="14" ry="5" fill="rgba(0,0,0,0.35)"/>
            </g>
          </svg>
          <span class="lever__hint">TIRAR ↓</span>
        </button>

      </div><!-- /.machine -->
    </div><!-- /.machine-wrap -->

    <!-- Hint rotar en mobile (fullscreen) -->
    <div id="rotate-hint" class="rotate-hint" hidden>Rotá el teléfono para mejor experiencia</div>

    <!-- Share -->
    <div class="share-row" id="share-row" hidden>
      <span class="share-label">Compartir esta frase</span>
      <div class="share-row__btns" id="share-btns"></div>
    </div>

  </section>

  <canvas id="ig-canvas" width="1080" height="1080" style="display:none;"></canvas>
</BaseLayout>

<script define:vars={{ frasesPool }}>
// ─── Shuffle bag ────────────────────────────────────────────────────────────
function shuffle(arr) {
  const a = [...arr];
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

function makeBag(pool, lastId) {
  let bag = shuffle(pool);
  // never start with the same frase we just showed
  if (bag.length > 1 && bag[0].id === lastId) {
    const tmp = bag[0]; bag[0] = bag[1]; bag[1] = tmp;
  }
  return bag;
}

// ─── State ──────────────────────────────────────────────────────────────────
let allPool = [...frasesPool];
let activePool = [...frasesPool];
let bag = [];
let fraseActual = null;
let autoMode = false;
let autoSpeed = 12000;
let autoTimer = null;
let wakeLock = null;
let activeCategoria = 'todas';

// ─── DOM refs ────────────────────────────────────────────────────────────────
const display    = document.getElementById('display');
const lever      = document.getElementById('lever');
const screen     = document.getElementById('screen');
const ledAuto    = document.getElementById('led-auto');
const machine    = document.getElementById('machine');
const tuner      = document.getElementById('tuner');
const btnAuto    = document.getElementById('btn-auto');
const btnFs      = document.getElementById('btn-fs');
const shareRow   = document.getElementById('share-row');
const shareBtns  = document.getElementById('share-btns');
const igCanvas   = document.getElementById('ig-canvas');
const rotateHint = document.getElementById('rotate-hint');
const speedBtns  = document.querySelectorAll('.speed-btn');

// ─── Category tuner ──────────────────────────────────────────────────────────
const CAT_LABELS = {
  todas: 'TODAS',
  filosofia: 'FILOSOFÍA',
  ciencia: 'CIENCIA',
  literatura: 'LITERATURA',
  cine: 'CINE',
  dicho: 'DICHOS',
  quiniela: 'QUINIELA',
  historia: 'HISTORIA',
  salehoy: 'SALEHOY',
  rock: 'ROCK',
  tango: 'TANGO',
  latam: 'LATAM',
};

function buildTuner() {
  const counts = {};
  for (const f of allPool) {
    counts[f.categoria] = (counts[f.categoria] || 0) + 1;
  }
  const visible = ['todas', ...Object.keys(counts).filter(c => counts[c] >= 5)];
  tuner.innerHTML = '';
  for (const cat of visible) {
    const btn = document.createElement('button');
    btn.className = 'tuner-btn' + (cat === activeCategoria ? ' tuner-btn--active' : '');
    btn.textContent = CAT_LABELS[cat] || cat.toUpperCase();
    btn.dataset.cat = cat;
    btn.addEventListener('click', () => selectCategoria(cat));
    tuner.appendChild(btn);
  }
}

function selectCategoria(cat) {
  activeCategoria = cat;
  activePool = cat === 'todas' ? [...allPool] : allPool.filter(f => f.categoria === cat);
  bag = [];
  document.querySelectorAll('.tuner-btn').forEach(b => {
    b.classList.toggle('tuner-btn--active', b.dataset.cat === cat);
  });
  pull();
}

// ─── Shuffle bag next ────────────────────────────────────────────────────────
function nextFrase() {
  if (bag.length === 0) bag = makeBag(activePool, fraseActual?.id ?? -1);
  return bag.shift();
}

// ─── CRT transition ──────────────────────────────────────────────────────────
const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

function crtTransition(cb) {
  if (prefersReduced) {
    display.style.transition = 'opacity 0.25s';
    display.style.opacity = '0';
    setTimeout(() => { cb(); display.style.opacity = '1'; }, 260);
    return;
  }
  // vertical collapse
  display.style.transition = 'transform 0.12s ease-in, opacity 0.1s ease-in';
  display.style.transform = 'scaleY(0)';
  display.style.opacity = '0.3';
  setTimeout(() => {
    cb();
    display.style.transition = 'transform 0.18s ease-out, opacity 0.15s ease-out';
    display.style.transform = 'scaleY(1)';
    display.style.opacity = '1';
  }, 140);
}

// ─── Adaptive font size ───────────────────────────────────────────────────────
function fontSizeForLength(len) {
  if (len < 60)  return 'clamp(20px, 4.5vw, 32px)';
  if (len < 120) return 'clamp(17px, 3.5vw, 26px)';
  return 'clamp(14px, 2.8vw, 21px)';
}

// ─── Render ──────────────────────────────────────────────────────────────────
function render(frase) {
  fraseActual = frase;
  const atrib = frase.obra ? `— ${frase.autor}, ${frase.obra}` : `— ${frase.autor}`;
  const fs = fontSizeForLength(frase.texto.length);
  display.innerHTML = `
    <p class="quote-text" style="font-size:${fs}">"${frase.texto}"</p>
    <div class="quote-atrib">${atrib}</div>
  `;
  shareRow.removeAttribute('hidden');
  renderShareButtons();
}

// ─── Pull ────────────────────────────────────────────────────────────────────
let pulling = false;

function pull(manual = false) {
  if (pulling) return;
  pulling = true;
  lever.disabled = true;

  if (manual) {
    lever.classList.add('lever--pulling');
    playSoundLever();
    resetAutoTimer();
  }

  const frase = nextFrase();
  crtTransition(() => render(frase));

  const delay = prefersReduced ? 300 : 350;
  setTimeout(() => {
    lever.classList.remove('lever--pulling');
    lever.disabled = false;
    pulling = false;
  }, delay);
}

// ─── Lever sound ─────────────────────────────────────────────────────────────
function playSoundLever() {
  try {
    const AudioCtx = window.AudioContext || window.webkitAudioContext;
    if (!AudioCtx) return;
    const ctx = new AudioCtx();
    const osc = ctx.createOscillator();
    const gain = ctx.createGain();
    osc.frequency.setValueAtTime(220, ctx.currentTime);
    osc.frequency.exponentialRampToValueAtTime(80, ctx.currentTime + 0.15);
    osc.type = 'sawtooth';
    gain.gain.setValueAtTime(0.04, ctx.currentTime);
    gain.gain.linearRampToValueAtTime(0, ctx.currentTime + 0.18);
    osc.connect(gain).connect(ctx.destination);
    osc.start();
    osc.stop(ctx.currentTime + 0.2);
  } catch {}
}

// ─── AUTO mode ───────────────────────────────────────────────────────────────
function setAutoMode(on) {
  autoMode = on;
  btnAuto.classList.toggle('ctrl-btn--auto-on', on);
  ledAuto.classList.toggle('led--blinking-cyan', on);
  machine.classList.toggle('machine--auto', on);

  if (on) {
    startAutoTimer();
    acquireWakeLock();
  } else {
    clearTimeout(autoTimer);
    autoTimer = null;
    releaseWakeLock();
  }
}

function startAutoTimer() {
  clearTimeout(autoTimer);
  if (!autoMode) return;
  autoTimer = setTimeout(() => {
    if (!document.hidden) pull();
    startAutoTimer();
  }, autoSpeed);
}

function resetAutoTimer() {
  if (autoMode) startAutoTimer();
}

// ─── Wake Lock ───────────────────────────────────────────────────────────────
async function acquireWakeLock() {
  try {
    if ('wakeLock' in navigator) {
      wakeLock = await navigator.wakeLock.request('screen');
    }
  } catch {}
}

function releaseWakeLock() {
  try { wakeLock?.release(); } catch {}
  wakeLock = null;
}

document.addEventListener('visibilitychange', () => {
  if (!document.hidden && autoMode) {
    acquireWakeLock();
    startAutoTimer();
  } else if (document.hidden && autoMode) {
    clearTimeout(autoTimer);
  }
});

// ─── Speed selector ──────────────────────────────────────────────────────────
speedBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    autoSpeed = Number(btn.dataset.speed);
    speedBtns.forEach(b => b.classList.remove('speed-btn--active'));
    btn.classList.add('speed-btn--active');
    if (autoMode) startAutoTimer();
  });
});

// ─── Fullscreen ───────────────────────────────────────────────────────────────
let isFullscreen = false;

function enterFullscreen() {
  const el = document.documentElement;
  try {
    (el.requestFullscreen || el.webkitRequestFullscreen || el.mozRequestFullScreen).call(el);
  } catch {}
  try {
    screen.orientation?.lock('landscape').catch(() => {});
  } catch {}
  isFullscreen = true;
  btnFs.querySelector('svg').innerHTML = '<path d="M4 1H1v3H0V0h4V1zm8 0h3v3h1V0h-4V1zM4 15H1v-3H0v4h4v-1zm8 0h3v-3h1v4h-4v-1z"/>';
  // show rotate hint on mobile, auto-hide after 3s
  if (window.innerWidth < 768) {
    rotateHint.removeAttribute('hidden');
    setTimeout(() => rotateHint.setAttribute('hidden', ''), 3000);
  }
}

function exitFullscreen() {
  try {
    (document.exitFullscreen || document.webkitExitFullscreen || document.mozCancelFullScreen).call(document);
  } catch {}
  isFullscreen = false;
  btnFs.querySelector('svg').innerHTML = '<path d="M1 1h5v2H3v3H1V1zm9 0h5v5h-2V3h-3V1zM1 10h2v3h3v2H1v-5zm12 3h-3v2h5v-5h-2v3z"/>';
}

document.addEventListener('fullscreenchange', () => {
  if (!document.fullscreenElement) {
    isFullscreen = false;
    btnFs.querySelector('svg').innerHTML = '<path d="M1 1h5v2H3v3H1V1zm9 0h5v5h-2V3h-3V1zM1 10h2v3h3v2H1v-5zm12 3h-3v2h5v-5h-2v3z"/>';
  }
});

// ─── Share ───────────────────────────────────────────────────────────────────
function renderShareButtons() {
  shareBtns.innerHTML = `
    <button class="share-btn share-btn--wa" data-action="whatsapp">
      <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/></svg> WhatsApp
    </button>
    <button class="share-btn share-btn--ig" data-action="instagram">IMG</button>
    <button class="share-btn" data-action="copy">Copiar</button>
    <button class="share-btn" data-action="native">Más…</button>
  `;
  shareBtns.querySelectorAll('[data-action]').forEach(btn => {
    btn.addEventListener('click', () => handleShare(btn.dataset.action, btn));
  });
}

async function handleShare(action, btn) {
  if (!fraseActual) return;
  const txt = fraseActual.obra
    ? `"${fraseActual.texto}" — ${fraseActual.autor}, ${fraseActual.obra}`
    : `"${fraseActual.texto}" — ${fraseActual.autor}`;
  const vianota = txt + '\n— vía SaleHoy';

  if (action === 'whatsapp') {
    window.open(`https://wa.me/?text=${encodeURIComponent(vianota)}`, '_blank');
  } else if (action === 'copy') {
    try {
      await navigator.clipboard.writeText(vianota);
      const o = btn.textContent; btn.textContent = 'Copiada ✓';
      setTimeout(() => btn.textContent = o, 1600);
    } catch {}
  } else if (action === 'native') {
    if (navigator.share) { try { await navigator.share({ text: vianota, title: 'SaleHoy' }); } catch {} }
  } else if (action === 'instagram') {
    downloadImage(fraseActual);
  }
}

function wrapText(ctx, text, maxWidth) {
  const words = text.split(' ');
  const lines = [];
  let current = '';
  for (const word of words) {
    const test = current ? current + ' ' + word : word;
    if (ctx.measureText(test).width > maxWidth && current) {
      lines.push(current); current = word;
    } else current = test;
  }
  if (current) lines.push(current);
  return lines;
}

function downloadImage(frase) {
  const ctx = igCanvas.getContext('2d');
  const W = 1080, H = 1080;
  // dark background with subtle CRT tint
  ctx.fillStyle = '#0a0f0a';
  ctx.fillRect(0, 0, W, H);
  // subtle scanlines
  for (let y = 0; y < H; y += 4) {
    ctx.fillStyle = 'rgba(0,255,80,0.025)';
    ctx.fillRect(0, y, W, 2);
  }
  // header line
  ctx.strokeStyle = '#1a4a20';
  ctx.lineWidth = 1;
  ctx.beginPath(); ctx.moveTo(80, 130); ctx.lineTo(W - 80, 130); ctx.stroke();

  // brand
  ctx.textAlign = 'left';
  ctx.fillStyle = '#4fff8d';
  ctx.font = "bold 28px 'VT323', monospace";
  ctx.fillText('MÁQUINA DE FRASES', 80, 110);
  ctx.textAlign = 'right';
  ctx.fillStyle = '#2a6a3a';
  ctx.font = "22px 'VT323', monospace";
  ctx.fillText('SALEHOY.COM.AR', W - 80, 110);

  // quote text
  ctx.textAlign = 'center';
  ctx.fillStyle = '#d8f5e0';
  const len = frase.texto.length;
  const qSize = len < 60 ? 72 : len < 120 ? 58 : len < 180 ? 46 : 36;
  ctx.font = `italic ${qSize}px Georgia, serif`;
  const quoteTxt = `"${frase.texto}"`;
  const lines = wrapText(ctx, quoteTxt, W - 180);
  const totalH = lines.length * (qSize + 12);
  let y = (H - totalH) / 2 - 60;
  for (const line of lines) {
    ctx.fillText(line, W / 2, y);
    y += qSize + 12;
  }

  // attribution
  ctx.fillStyle = '#4fff8d';
  ctx.font = `500 34px Georgia, serif`;
  const atrib = frase.obra ? `— ${frase.autor}, ${frase.obra}` : `— ${frase.autor}`;
  ctx.fillText(atrib, W / 2, y + 48);

  // footer line
  ctx.strokeStyle = '#1a4a20';
  ctx.beginPath(); ctx.moveTo(80, H - 100); ctx.lineTo(W - 100, H - 100); ctx.stroke();
  ctx.textAlign = 'center';
  ctx.fillStyle = '#2a6a3a';
  ctx.font = "24px 'VT323', monospace";
  ctx.fillText('MÁQUINA DE FRASES · salehoy.com.ar', W / 2, H - 65);

  igCanvas.toBlob(blob => {
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `salehoy-${(frase.autor.split(' ')[0] || 'frase').toLowerCase()}.png`;
    document.body.appendChild(a); a.click(); document.body.removeChild(a);
    setTimeout(() => URL.revokeObjectURL(url), 1000);
  }, 'image/png');
}

// ─── Event listeners ──────────────────────────────────────────────────────────
lever.addEventListener('click', () => pull(true));

btnAuto.addEventListener('click', () => setAutoMode(!autoMode));

btnFs.addEventListener('click', () => {
  if (isFullscreen) exitFullscreen(); else enterFullscreen();
});

document.addEventListener('keydown', e => {
  const tag = document.activeElement?.tagName;
  if (tag === 'INPUT' || tag === 'TEXTAREA') return;
  if (e.code === 'Space') { e.preventDefault(); pull(true); }
  if (e.key === 'a' || e.key === 'A') setAutoMode(!autoMode);
  if (e.key === 'f' || e.key === 'F') {
    if (isFullscreen) exitFullscreen(); else enterFullscreen();
  }
});

// ─── Init ────────────────────────────────────────────────────────────────────
buildTuner();
// first pull on load (no lever sound, no manual)
pull(false);
</script>

