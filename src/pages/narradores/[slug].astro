---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const narradores = await getCollection('narradores');
  return narradores.map(n => ({
    params: { slug: n.data.slug },
    props: { narrador: n },
  }));
}

const { narrador } = Astro.props;

const articulos = (await getCollection('articulos'))
  .filter(a => a.data.narrador === narrador.data.slug)
  .sort((a, b) => b.data.fecha.valueOf() - a.data.fecha.valueOf());

const acentoMap: Record<string, string> = {
  'la-cientifica':  '#C9A96E',
  'la-pitonisa':    '#9B2226',
  'el-matematico':  '#4A9070',
  'el-cronista':    '#8B6040',
  'el-historiador': '#4A2818',
};

const cadenciaMap: Record<string, string> = {
  'la-cientifica':  'Mensual · último viernes',
  'la-pitonisa':    'Por número · sábado',
  'el-matematico':  'Mensual · cierre de mes',
  'el-cronista':    'Por número · jueves',
  'el-historiador': 'Mensual · primer sábado',
};

const columnKindMap: Record<string, string> = {
  'la-cientifica':  'Nota clínica · cuida los temas sensibles',
  'la-pitonisa':    'Columna abierta · oracle vivo',
  'el-matematico':  'La Data · análisis de quiniela',
  'el-cronista':    'Crónica larga · ritmo radial',
  'el-historiador': 'Ensayo histórico · una figura por edición',
};

const quoteMap: Record<string, { texto: string; fuente: string }> = {
  'la-cientifica':  {
    texto: 'Yo lo que sé del psicoanálisis argentino lo aprendí de dos lados: la formación con Silvia, y de chica, oyendo a mi viejo hablar con sus amigos en la cocina.',
    fuente: 'Ponencia, congreso de la AAP, 2019',
  },
  'la-pitonisa':    {
    texto: 'Los números no mienten, mijita. Lo que mienten son las cuentas que una se hace con ellos.',
    fuente: 'Anotado en el margen de un cuaderno Gloria, 1998',
  },
  'el-matematico':  {
    texto: 'Las casas de apuestas no ganan porque sepan más que vos. Ganan porque tienen más tiempo del que vos podés invertir.',
    fuente: 'La Data, edición VIII, SaleHoy',
  },
  'el-cronista':    {
    texto: 'El que apostó fuerte alguna vez no escribe contra la apuesta. Escribe desde adentro, y por eso baja la voz.',
    fuente: 'Programa La Hora Perdida, FM Río Cuarto, 2024',
  },
  'el-historiador': {
    texto: 'El pasado no se estudia. Se interroga.',
    fuente: 'Conversación, librería de viejo, calle Corrientes',
  },
};

const acento = acentoMap[narrador.data.slug] ?? 'var(--color-accent-gold)';
const quote = quoteMap[narrador.data.slug];
const cadencia = cadenciaMap[narrador.data.slug];
const columnKind = columnKindMap[narrador.data.slug];

const iniciales = narrador.data.nombre.split(' ').map((w: string) => w[0]).join('');
---

<BaseLayout
  title={narrador.data.nombre}
  description={`${narrador.data.disciplina}. ${narrador.data.preguntaDeFondo}`}
>
  <article class="dossier" style={`--n-accent: ${acento};`}>

    <!-- Breadcrumb -->
    <div class="dossier__back container-wide">
      <a href="/narradores">← Los narradores</a>
    </div>

    <!-- Header strip -->
    <header class="dossier__header container-wide">
      <div class="dossier__header-text">
        <span class="dossier__role">{narrador.data.disciplina}</span>
        <h1 class="dossier__name">{narrador.data.nombre}</h1>
        <p class="dossier__pregunta">{narrador.data.preguntaDeFondo}</p>
      </div>
      <div class="dossier__header-orn" aria-hidden="true">
        <div class="dossier__orn-icon">
          <svg viewBox="0 0 16 20" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="8" cy="5.5" r="3.2"/>
            <circle cx="4" cy="11" r="3.2"/>
            <circle cx="12" cy="11" r="3.2"/>
            <line x1="8" y1="13.5" x2="8" y2="19"/>
          </svg>
        </div>
        <div class="dossier__iniciales">{iniciales}</div>
      </div>
    </header>

    <!-- Bio + quote | Metadata -->
    <div class="dossier__body container-wide">

      <section class="dossier__bio-section">
        <span class="dossier__section-label">Perfil</span>
        <p class="dossier__bio">{narrador.data.bio}</p>

        {quote && (
          <blockquote class="dossier__quote">
            «{quote.texto}»
            <cite class="dossier__quote-cite">— {quote.fuente}</cite>
          </blockquote>
        )}
      </section>

      <aside class="dossier__meta">
        <span class="dossier__section-label">Columna</span>
        <dl class="dossier__dl">
          {columnKind && (
            <div class="dossier__dl-row">
              <dt>Formato</dt>
              <dd>{columnKind}</dd>
            </div>
          )}
          {cadencia && (
            <div class="dossier__dl-row">
              <dt>Cadencia</dt>
              <dd>{cadencia}</dd>
            </div>
          )}
          <div class="dossier__dl-row">
            <dt>Artículos</dt>
            <dd>{articulos.length} publicado{articulos.length !== 1 ? 's' : ''}</dd>
          </div>
          <div class="dossier__dl-row">
            <dt>Tono</dt>
            <dd>{narrador.data.tono?.split('.')[0] ?? '—'}</dd>
          </div>
        </dl>
      </aside>

    </div>

    <!-- Articles -->
    <section class="dossier__articles container-wide">
      <h2 class="dossier__articles-title">
        {articulos.length > 0
          ? `Artículos firmados (${articulos.length})`
          : 'Artículos firmados'}
      </h2>
      {articulos.length === 0 ? (
        <p class="dossier__empty">Próxima publicación en el número #01.</p>
      ) : (
        <div class="articles-grid">
          {articulos.map(articulo => (
            <ArticleCard articulo={articulo} narradorNombre={narrador.data.nombre} size="md" />
          ))}
        </div>
      )}
    </section>

  </article>
</BaseLayout>

<style>
  .dossier {
    padding-block: var(--space-2xl) var(--space-4xl);
  }

  /* ============================================================
     Breadcrumb
     ============================================================ */
  .dossier__back {
    margin-bottom: var(--space-xl);
  }

  .dossier__back a {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-leather);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .dossier__back a:hover { color: var(--color-text); }

  /* ============================================================
     Header
     ============================================================ */
  .dossier__header {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: var(--space-xl);
    align-items: start;
    padding-top: var(--space-xl);
    border-top: 3px solid var(--n-accent);
    margin-bottom: var(--space-2xl);
  }

  @media (max-width: 640px) {
    .dossier__header { grid-template-columns: 1fr; }
    .dossier__header-orn { display: none; }
  }

  .dossier__role {
    display: inline-block;
    font-family: var(--font-display);
    font-variant-caps: all-small-caps;
    font-feature-settings: "smcp", "c2sc";
    font-size: var(--text-sm);
    letter-spacing: 0.16em;
    color: var(--n-accent);
    margin-bottom: var(--space-sm);
  }

  .dossier__name {
    font-family: var(--font-display);
    font-weight: var(--font-bold);
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.02;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 0 var(--space-md);
  }

  .dossier__pregunta {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-xl);
    line-height: 1.45;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 44ch;
  }

  .dossier__header-orn {
    text-align: center;
    padding-top: var(--space-sm);
  }

  .dossier__orn-icon {
    width: 48px;
    height: 62px;
    color: var(--n-accent);
    margin: 0 auto var(--space-sm);
    opacity: 0.8;
  }

  .dossier__iniciales {
    font-family: var(--font-display);
    font-variant-caps: all-small-caps;
    font-feature-settings: "smcp", "c2sc";
    font-size: var(--text-xs);
    letter-spacing: 0.18em;
    color: var(--color-leather);
  }

  /* ============================================================
     Body: bio + metadata
     ============================================================ */
  .dossier__body {
    display: grid;
    grid-template-columns: 1.3fr 1fr;
    gap: var(--space-3xl);
    margin-bottom: var(--space-3xl);
  }

  @media (max-width: 768px) {
    .dossier__body { grid-template-columns: 1fr; }
  }

  .dossier__section-label {
    display: inline-block;
    font-family: var(--font-display);
    font-variant-caps: all-small-caps;
    font-feature-settings: "smcp", "c2sc";
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    color: var(--n-accent);
    margin-bottom: var(--space-md);
  }

  .dossier__bio {
    font-family: var(--font-display);
    font-size: 1.125rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
    margin: 0 0 var(--space-xl);
    text-wrap: pretty;
    /* Drop cap */
  }

  .dossier__bio::first-letter {
    font-family: var(--font-display);
    font-weight: var(--font-bold);
    font-size: 4.2em;
    line-height: 0.86;
    color: var(--n-accent);
    float: left;
    padding: 0.08em 0.08em 0 0;
    margin-right: 0.02em;
  }

  .dossier__quote {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-xl);
    line-height: 1.5;
    color: var(--color-text);
    border: none;
    border-left: 2px solid var(--n-accent);
    padding: 0 0 0 var(--space-lg);
    margin: 0;
    max-width: 44ch;
  }

  .dossier__quote-cite {
    display: block;
    font-style: normal;
    font-family: var(--font-display);
    font-variant-caps: all-small-caps;
    font-feature-settings: "smcp", "c2sc";
    font-size: var(--text-xs);
    letter-spacing: 0.16em;
    color: var(--color-leather);
    margin-top: var(--space-md);
  }

  /* Metadata */
  .dossier__dl {
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  .dossier__dl-row {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-md);
    padding: var(--space-md) 0;
    border-bottom: 1px dotted var(--color-line);
    font-family: var(--font-display);
    font-size: var(--text-sm);
  }

  .dossier__dl-row:last-child {
    border-bottom: none;
  }

  .dossier__dl-row dt {
    font-variant-caps: all-small-caps;
    font-feature-settings: "smcp", "c2sc";
    letter-spacing: 0.12em;
    color: var(--color-leather);
    flex-shrink: 0;
  }

  .dossier__dl-row dd {
    margin: 0;
    font-style: italic;
    color: var(--color-text);
    text-align: right;
  }

  /* ============================================================
     Articles
     ============================================================ */
  .dossier__articles {
    padding-top: var(--space-2xl);
    border-top: 1px solid var(--color-line);
  }

  .dossier__articles-title {
    font-family: var(--font-display);
    font-weight: var(--font-semibold);
    font-size: var(--text-2xl);
    letter-spacing: -0.005em;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
  }

  .articles-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 768px) {
    .articles-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .articles-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .dossier__empty {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-text-secondary);
  }
</style>
