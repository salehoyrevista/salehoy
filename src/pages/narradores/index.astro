---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const narradores = await getCollection('narradores');
const articulos = await getCollection('articulos');

const counts = new Map<string, number>();
articulos.forEach(a => {
  counts.set(a.data.narrador, (counts.get(a.data.narrador) ?? 0) + 1);
});

const acentoMap: Record<string, string> = {
  'la-cientifica':  '#C9A96E',
  'la-pitonisa':    '#9B2226',
  'el-matematico':  '#4A9070',
  'el-cronista':    '#8B6040',
  'el-historiador': '#4A2818',
};

const cadenciaMap: Record<string, string> = {
  'la-cientifica':  'Mensual · último viernes',
  'la-pitonisa':    'Por número · sábado',
  'el-matematico':  'Mensual · cierre de mes',
  'el-cronista':    'Por número · jueves',
  'el-historiador': 'Mensual · primer sábado',
};

const columnKindMap: Record<string, string> = {
  'la-cientifica':  'Nota clínica',
  'la-pitonisa':    'Oracle vivo',
  'el-matematico':  'La Data · estadística',
  'el-cronista':    'Crónica larga',
  'el-historiador': 'Ensayo histórico',
};
---

<BaseLayout
  title="Los narradores"
  description="Las cinco voces de SaleHoy: La Vichy, La Científica, El Matemático, El Cronista, El Historiador."
>

  <!-- Hero -->
  <section class="narr-hero container-narrow">
    <span class="narr-eyebrow">Los narradores</span>
    <h1 class="narr-title">Las cinco voces</h1>
    <p class="narr-deck">
      Cinco disciplinas, cinco lugares, una agenda propia. Conviven sin citarse — cada nota se sostiene sola.
    </p>
    <div class="narr-rule" aria-hidden="true">
      <span class="narr-rule__line"></span>
      <span class="narr-rule__sym">✦</span>
      <span class="narr-rule__line"></span>
    </div>
  </section>

  <!-- Tile grid de 5 -->
  <section class="tile-grid container-wide" aria-label="Los cinco narradores">
    {narradores.map(n => {
      const acento = acentoMap[n.data.slug] ?? 'var(--color-accent-gold)';
      return (
        <a
          href={`/narradores/${n.data.slug}`}
          class="tile"
          style={`--n-accent: ${acento};`}
        >
          <div class="tile__ornament" aria-hidden="true">
            <svg viewBox="0 0 16 20" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="8" cy="5.5" r="3.2"/>
              <circle cx="4" cy="11" r="3.2"/>
              <circle cx="12" cy="11" r="3.2"/>
              <line x1="8" y1="13.5" x2="8" y2="19"/>
            </svg>
          </div>
          <span class="tile__role">{columnKindMap[n.data.slug] ?? n.data.disciplina}</span>
          <h2 class="tile__name">{n.data.nombre}</h2>
          <p class="tile__disc">{n.data.preguntaDeFondo}</p>
          <div class="tile__count">
            {counts.get(n.data.slug) ?? 0} {(counts.get(n.data.slug) ?? 0) === 1 ? 'artículo' : 'artículos'}
          </div>
        </a>
      );
    })}
  </section>

  <!-- Listado detallado -->
  <section class="narr-rows container-wide" aria-label="Sumario de narradores">
    <h2 class="narr-rows__heading">Sumario · firmas y cadencia</h2>
    {narradores.map(n => {
      const acento = acentoMap[n.data.slug] ?? 'var(--color-accent-gold)';
      const cadencia = cadenciaMap[n.data.slug] ?? '';
      return (
        <a
          href={`/narradores/${n.data.slug}`}
          class="narr-row"
          style={`--n-accent: ${acento};`}
        >
          <div class="narr-row__disc">{n.data.disciplina}</div>
          <div class="narr-row__main">
            <h3 class="narr-row__name">{n.data.nombre}</h3>
            <p class="narr-row__bio">
              {n.data.bio.split('.').slice(0, 2).join('.') + '.'}
            </p>
          </div>
          <div class="narr-row__meta">
            {cadencia && <div class="narr-row__cadencia">{cadencia}</div>}
            <div class="narr-row__orn" aria-hidden="true">
              <svg viewBox="0 0 16 20" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="8" cy="5.5" r="3.2"/>
                <circle cx="4" cy="11" r="3.2"/>
                <circle cx="12" cy="11" r="3.2"/>
                <line x1="8" y1="13.5" x2="8" y2="19"/>
              </svg>
            </div>
          </div>
        </a>
      );
    })}
  </section>

</BaseLayout>

<style>
  /* ============================================================
     Hero
     ============================================================ */
  .narr-hero {
    text-align: center;
    padding-top: var(--space-3xl);
    margin-bottom: var(--space-2xl);
  }

  .narr-eyebrow {
    display: inline-block;
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-leather);
    margin-bottom: var(--space-md);
  }

  .narr-title {
    font-family: var(--font-display);
    font-weight: var(--font-bold);
    font-size: clamp(2.5rem, 6vw, 3.5rem);
    line-height: 1.04;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin: 0 auto var(--space-md);
    font-variant-caps: small-caps;
  }

  .narr-deck {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--color-text-secondary);
    max-width: 52ch;
    margin: 0 auto var(--space-xl);
  }

  .narr-rule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-md);
    margin-bottom: var(--space-2xl);
  }

  .narr-rule__line {
    display: block;
    width: 48px;
    height: 1px;
    background: var(--color-leather);
    opacity: 0.5;
  }

  .narr-rule__sym {
    font-size: var(--text-sm);
    color: var(--color-leather);
    opacity: 0.7;
  }

  /* ============================================================
     Tile grid
     ============================================================ */
  .tile-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-md);
    margin-bottom: var(--space-3xl);
  }

  @media (max-width: 1100px) {
    .tile-grid { grid-template-columns: repeat(3, 1fr); }
  }

  @media (max-width: 640px) {
    .tile-grid { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 400px) {
    .tile-grid { grid-template-columns: 1fr; }
  }

  .tile {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg) var(--space-md) var(--space-xl);
    border-top: 2px solid var(--n-accent);
    background: var(--color-bg-elevated);
    text-decoration: none;
    color: inherit;
    transition: border-top-width 150ms ease, background 150ms ease;
  }

  .tile:hover {
    border-top-width: 3px;
    background: var(--color-bg-subtle);
  }

  .tile__ornament {
    width: 22px;
    height: 28px;
    color: var(--n-accent);
    margin: 0 auto var(--space-md);
  }

  .tile__role {
    display: block;
    font-family: var(--font-display);
    font-variant-caps: all-small-caps;
    font-feature-settings: "smcp", "c2sc";
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    color: var(--n-accent);
    margin-bottom: var(--space-xs);
    text-align: center;
  }

  .tile__name {
    font-family: var(--font-display);
    font-weight: var(--font-semibold);
    font-size: var(--text-xl);
    letter-spacing: -0.005em;
    color: var(--color-text);
    margin: 0 0 var(--space-sm);
    text-align: center;
    text-wrap: balance;
  }

  .tile__disc {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-sm);
    line-height: 1.45;
    color: var(--color-text-secondary);
    margin: 0 0 auto;
    text-wrap: pretty;
    text-align: center;
  }

  .tile__count {
    margin-top: var(--space-md);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    text-align: center;
  }

  /* ============================================================
     Listado detallado
     ============================================================ */
  .narr-rows {
    margin-bottom: var(--space-4xl);
  }

  .narr-rows__heading {
    font-family: var(--font-display);
    font-weight: var(--font-semibold);
    font-size: var(--text-2xl);
    letter-spacing: -0.005em;
    color: var(--color-text);
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-md);
    border-bottom: 1px solid var(--color-line);
  }

  .narr-row {
    display: grid;
    grid-template-columns: 200px 1fr auto;
    gap: var(--space-xl);
    align-items: start;
    padding: var(--space-xl) 0;
    border-bottom: 1px solid var(--color-line);
    text-decoration: none;
    color: inherit;
    transition: border-bottom-color var(--transition-fast);
  }

  .narr-row:hover {
    border-bottom-color: var(--n-accent);
  }

  @media (max-width: 768px) {
    .narr-row {
      grid-template-columns: 1fr;
      gap: var(--space-sm);
    }
    .narr-row__meta { display: flex; align-items: center; gap: var(--space-md); }
    .narr-row__orn { display: none; }
  }

  .narr-row__disc {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--font-semibold);
    letter-spacing: 0.10em;
    text-transform: uppercase;
    color: var(--color-leather);
    padding-top: var(--space-xs);
  }

  .narr-row__name {
    font-family: var(--font-display);
    font-weight: var(--font-semibold);
    font-size: var(--text-2xl);
    letter-spacing: -0.005em;
    color: var(--n-accent);
    margin: 0 0 var(--space-sm);
    transition: color var(--transition-fast);
  }

  .narr-row:hover .narr-row__name {
    color: var(--color-text);
  }

  .narr-row__bio {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--text-md);
    line-height: 1.55;
    color: var(--color-text-secondary);
    margin: 0;
    max-width: 62ch;
  }

  .narr-row__meta {
    text-align: center;
    padding-top: var(--space-xs);
  }

  .narr-row__cadencia {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-sm);
    white-space: nowrap;
  }

  .narr-row__orn {
    width: 20px;
    height: 26px;
    color: var(--n-accent);
    margin: 0 auto;
    opacity: 0.7;
  }
</style>
