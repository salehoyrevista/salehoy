---
/**
 * ZonaInforme.astro — Informe completo de una zona quiniela
 * Recibe zonaKey ('nacional' | 'buenosAires' | 'cordoba'), datos y textos.
 */
import BarChart from './BarChart.astro';
import {
  formatMes,
  formatVsPromedio,
  formatPct,
  renderProseHTML,
  renderInlineHTML,
  peakDecada,
  PALETAS,
  ZONA_NOMBRE,
  ZONA_SLUG,
  formatDateShort,
  formatGeneradoEl,
} from '../../lib/la-data';

interface Props {
  zonaKey: string;
  datos: any;
  textos: any;
}

const { zonaKey, datos, textos } = Astro.props;

// ── Datos de zona ──────────────────────────────────────────────────────────────
const zona = datos.zonas[zonaKey];
const { sorteos, extracciones, dosCifras, terminaciones, tresCifras, cuatroCifras, porMilar, aPrimera } = zona;
const { top, bottom, porDecada, esperadoPorNumero } = dosCifras;

// ── Textos de zona ─────────────────────────────────────────────────────────────
const texZona = textos.zonas?.[zonaKey] ?? {};
const apertura = texZona.apertura ?? '';
const aperturaTitle = texZona.aperturaTitle ?? '';
const tema = texZona.tema ?? '';
const temaTitle = texZona.temaTitle ?? '';
const cierre = texZona.cierre ?? '';
const cajas: any[] = texZona.cajas ?? [];

// ── Paleta ────────────────────────────────────────────────────────────────────
const paleta = PALETAS[zonaKey];
const accent = paleta.accent;
const bg = paleta.bg;

// ── Meta ──────────────────────────────────────────────────────────────────────
const mesStr = textos.label as string; // "2026-05"
const mesLabel = formatMes(mesStr);
const zonaNombre = ZONA_NOMBRE[zonaKey] ?? zonaKey;
const generadoEl = formatGeneradoEl(datos.generadoEl);

// ── Ticker ────────────────────────────────────────────────────────────────────
const tickerExtra = textos.ticker ? ` · ${textos.ticker}` : '';
const tickerText = `${zonaNombre.toUpperCase()} · ${mesLabel.toUpperCase()} · ${formatDateShort(datos.periodo.desde)}→${formatDateShort(datos.periodo.hasta)} · ${sorteos} sorteos · ${extracciones} extracciones · act.${generadoEl}${tickerExtra}`;

// ── Década peak/low ───────────────────────────────────────────────────────────
const { peak, low } = peakDecada(porDecada);

// ── SVG top frecuencia ────────────────────────────────────────────────────────
const maxAp = Math.max(...top.map((t: any) => t.apariciones));
const SVG_TOP_ROW_H = 32;
const SVG_TOP_PAD = 24;
const svgTopH = top.length * SVG_TOP_ROW_H + SVG_TOP_PAD;
const svgBarMaxW = 320;
const expectedWidth = Math.round((esperadoPorNumero / maxAp) * svgBarMaxW);

// ── Datos para BarChart décadas ───────────────────────────────────────────────
const decadaItems = porDecada.map((d: any) => ({ label: d.rango, value: d.apariciones }));
const terminacionItems = terminaciones.map((t: any) => ({ label: t.digito, value: t.apariciones }));
const { peak: termPeak, low: termLow } = peakDecada(terminaciones.map((t: any) => ({ rango: t.digito, apariciones: t.apariciones })));

// ── Nav inter-zonas ───────────────────────────────────────────────────────────
// Comparativa usa fondo claro (#1B1F2A) que es invisible en zonas oscuras;
// se fuerza a usar el acento de la zona actual al 60% para que sea legible.
const otrasZonas = [
  { key: 'nacional',    nombre: 'Nacional',    slug: 'nacional',    navAccent: PALETAS.nacional.accent,    navBg: PALETAS.nacional.bg },
  { key: 'buenosAires', nombre: 'Buenos Aires', slug: 'buenos-aires', navAccent: PALETAS.buenosAires.accent, navBg: PALETAS.buenosAires.bg },
  { key: 'cordoba',     nombre: 'Córdoba',     slug: 'cordoba',     navAccent: PALETAS.cordoba.accent,     navBg: PALETAS.cordoba.bg },
  { key: 'comparativa', nombre: 'Comparativa', slug: 'comparativa', navAccent: accent,                    navBg: bg },
].filter(z => z.key !== zonaKey);

// ── Turista (solo Córdoba) ────────────────────────────────────────────────────
const turista = zonaKey === 'cordoba' ? zona.turista : null;

interface TuristaGroup {
  apariciones: number;
  numeros: string[];
}

function agruparPorApariciones(arr: any[]): TuristaGroup[] {
  const map = new Map<number, string[]>();
  for (const item of arr) {
    const key = item.apariciones;
    if (!map.has(key)) map.set(key, []);
    map.get(key)!.push(item.numero);
  }
  return Array.from(map.entries())
    .sort((a, b) => b[0] - a[0])
    .map(([apariciones, numeros]) => ({ apariciones, numeros }));
}

const gruposTurista: TuristaGroup[] = turista ? agruparPorApariciones(turista.top) : [];
const turistaVisibles = gruposTurista.slice(0, 2);
const turistaOcultos = gruposTurista.slice(2);
---

<div
  class="ld-zona"
  style={`--ld-bg:${bg}; --ld-accent:${accent}; --ld-is-dark:1`}
>

  <!-- A. Breadcrumb -->
  <nav class="ld-crumbs" aria-label="Migas de pan">
    <a href="/la-sala" class="ld-crumb">★ LA SALA</a>
    <span class="ld-crumb-sep" aria-hidden="true">›</span>
    <a href="/la-data" class="ld-crumb">LA DATA</a>
    <span class="ld-crumb-sep" aria-hidden="true">›</span>
    <span class="ld-crumb ld-crumb--current" aria-current="page">{zonaNombre.toUpperCase()}</span>
  </nav>

  <!-- B. Hero full-bleed -->
  <section class="ld-hero">

    <!-- Ticker marquee CSS-only -->
    <div class="ld-ticker" aria-label="Datos del mes" role="marquee">
      <div class="ld-ticker__track">
        <span class="ld-ticker__txt">{tickerText} &nbsp;·&nbsp; {tickerText} &nbsp;·&nbsp;</span>
        <span class="ld-ticker__txt" aria-hidden="true">{tickerText} &nbsp;·&nbsp; {tickerText} &nbsp;·&nbsp;</span>
      </div>
    </div>

    <!-- Identidad zona -->
    <div class="ld-hero__head container-wide">
      <p class="ld-hero__eyebrow">QUINIELA</p>
      <h1 class="ld-hero__nombre">{zonaNombre}</h1>
      <p class="ld-hero__periodo">{mesLabel}</p>
    </div>

    <!-- Stats trio -->
    <div class="ld-hero__stats container-wide">
      <div class="ld-stat">
        <span class="ld-stat__num">{sorteos}</span>
        <span class="ld-stat__label">sorteos</span>
      </div>
      <div class="ld-stat">
        <span class="ld-stat__num">{extracciones}</span>
        <span class="ld-stat__label">extracciones</span>
      </div>
      <div class="ld-stat">
        <span class="ld-stat__num">{datos.periodo.dias}</span>
        <span class="ld-stat__label">días</span>
      </div>
    </div>

    <!-- Resumen rápido derivado de datos -->
    <div class="ld-resumen container-wide">
      <div class="ld-resumen__celda">
        <p class="ld-resumen__label">Más salido</p>
        <p class="ld-resumen__val">{top[0].numero}</p>
        <p class="ld-resumen__sub">{top[0].apariciones}v · {formatVsPromedio(top[0].vsPromedio)}</p>
      </div>
      <div class="ld-resumen__celda">
        <p class="ld-resumen__label">Menos salido</p>
        <p class="ld-resumen__val">{bottom[0].numero}</p>
        <p class="ld-resumen__sub">{bottom[0].apariciones}v · {formatVsPromedio(bottom[0].vsPromedio)}</p>
      </div>
      <div class="ld-resumen__celda">
        <p class="ld-resumen__label">Década caliente</p>
        <p class="ld-resumen__val">{peak.rango}</p>
        <p class="ld-resumen__sub">{peak.apariciones} ap.</p>
      </div>
      <div class="ld-resumen__celda">
        <p class="ld-resumen__label">Top tres cifras</p>
        <p class="ld-resumen__val">{tresCifras.top[0].numero}</p>
        <p class="ld-resumen__sub">{tresCifras.top[0].apariciones} veces</p>
      </div>
    </div>

    <!-- Nav inter-zonas -->
    <nav class="ld-zonanav container-wide" aria-label="Otras zonas">
      {otrasZonas.map(z => (
        <a
          href={`/la-data/${z.slug}`}
          class="ld-zonanav__link"
          style={`--zn-accent:${z.navAccent}; --zn-bg:${z.navBg}`}
        >
          {z.nombre}
        </a>
      ))}
    </nav>

  </section>

  <!-- C. Apertura editorial -->
  {apertura && (
    <section class="ld-apertura container-prose">
      {aperturaTitle && <h2 class="ld-section-title">{aperturaTitle}</h2>}
      <div set:html={renderProseHTML(apertura)} />
    </section>
  )}

  <!-- D. Charts -->
  <section class="ld-charts container-wide">
    <h2 class="ld-section-title">Distribución · {mesLabel}</h2>

    <div class="ld-charts__grid">
      <div class="ld-charts__main">
        <p class="ld-charts__subtitle">Por década</p>
        <BarChart
          items={decadaItems}
          peakLabel={peak.rango}
          lowLabel={low.rango}
          accent={accent}
          title={`Distribución por década — ${zonaNombre} ${mesLabel}`}
        />
      </div>
      <div class="ld-charts__side">
        <p class="ld-charts__subtitle">Terminaciones 0–9</p>
        <BarChart
          items={terminacionItems}
          peakLabel={termPeak.rango}
          lowLabel={termLow.rango}
          accent={accent}
          title={`Terminaciones 0 a 9 — ${zonaNombre} ${mesLabel}`}
        />
      </div>
    </div>

    <!-- Top frecuencia — SVG horizontal inline -->
    <div class="ld-charts__top">
      <p class="ld-charts__subtitle">Top frecuencia (dos cifras)</p>
      <svg
        viewBox={`0 0 440 ${svgTopH}`}
        role="img"
        aria-label={`Top números por frecuencia — ${zonaNombre}`}
        class="ld-topsvg"
        xmlns="http://www.w3.org/2000/svg"
      >
        {top.map((t: any, i: number) => {
          const yBase = 36 + i * SVG_TOP_ROW_H;
          const barW = Math.round((t.apariciones / maxAp) * svgBarMaxW);
          const barX = 40;
          const isPos = t.vsPromedio >= 0;
          const vsColor = isPos ? accent : '#e07040';
          return (
            <>
              {/* Número */}
              <text
                x={32}
                y={yBase}
                text-anchor="end"
                font-family="'JetBrains Mono', monospace"
                font-size="13"
                font-weight="600"
                fill={accent}
              >
                {t.numero}
              </text>
              {/* Barra de referencia (esperado) */}
              <rect
                x={barX}
                y={yBase - 14}
                width={expectedWidth}
                height={18}
                rx="2"
                fill="none"
                stroke={accent}
                stroke-opacity="0.3"
                stroke-width="1"
                stroke-dasharray="3 2"
              />
              {/* Barra principal */}
              <rect
                x={barX}
                y={yBase - 14}
                width={barW}
                height={18}
                rx="2"
                fill={accent}
                fill-opacity="0.65"
              />
              {/* Valor */}
              <text
                x={barX + barW + 6}
                y={yBase}
                font-family="'JetBrains Mono', monospace"
                font-size="11"
                fill={accent}
                fill-opacity="0.85"
              >
                {t.apariciones}v
              </text>
              {/* vsPromedio */}
              <text
                x={420}
                y={yBase}
                text-anchor="end"
                font-family="'JetBrains Mono', monospace"
                font-size="11"
                font-weight="600"
                fill={vsColor}
              >
                {formatVsPromedio(t.vsPromedio)}
              </text>
            </>
          );
        })}
      </svg>
    </div>
  </section>

  <!-- E. Tema editorial -->
  {tema && (
    <section class="ld-tema container-prose">
      {temaTitle && <h2 class="ld-tema__title">{temaTitle}</h2>}
      <div class="ld-tema__prose has-drop-cap" set:html={renderProseHTML(tema)} />
    </section>
  )}

  <!-- F. Cajas de dato -->
  {cajas.filter((c: any) => c.label).length > 0 && (
    <section class="ld-cajas container-wide">
      {cajas.filter((c: any) => c.label).map((c: any) => (
        <article class="ld-caja">
          <p class="ld-caja__label">{c.label}</p>
          <p class="ld-caja__valor">
            {c.valor}
            {c.valorNota && <small class="ld-caja__nota">{c.valorNota}</small>}
          </p>
          {c.texto && <p class="ld-caja__texto" set:html={renderInlineHTML(c.texto)} />}
        </article>
      ))}
    </section>
  )}

  <!-- G. Detalle estadístico -->
  <section class="ld-detalle container-wide">

    <div class="ld-panel">
      <h3 class="ld-panel__title">Los más salidos del mes</h3>
      <ol class="ld-numlist">
        {top.map((t: any) => (
          <li>
            <span class="ld-num">{t.numero}</span>
            {' '}{t.apariciones} veces{' '}
            <span class="ld-vs ld-vs--pos">{formatVsPromedio(t.vsPromedio)}</span>
          </li>
        ))}
      </ol>
    </div>

    <div class="ld-panel">
      <h3 class="ld-panel__title">Los menos salidos</h3>
      <ol class="ld-numlist">
        {bottom.map((b: any) => (
          <li>
            <span class="ld-num">{b.numero}</span>
            {' '}{b.apariciones} veces{' '}
            <span class="ld-vs ld-vs--neg">{formatVsPromedio(b.vsPromedio)}</span>
          </li>
        ))}
      </ol>
    </div>

    <div class="ld-panel">
      <h3 class="ld-panel__title">Tres cifras destacadas</h3>
      <p class="ld-panel__meta">{tresCifras.unicos} únicos · {tresCifras.repetidos2omas} se repitieron 2+ veces</p>
      <ol class="ld-numlist ld-numlist--tres">
        {tresCifras.top.map((t: any) => (
          <li>
            <span class="ld-num">{t.numero}</span>
            {' '}× {t.apariciones}
          </li>
        ))}
      </ol>
    </div>

    <div class="ld-panel">
      <h3 class="ld-panel__title">Cuatro cifras</h3>
      <p class="ld-panel__meta">{cuatroCifras.unicos} combinaciones únicas · {cuatroCifras.repetidos2omas} se repitieron 2+ veces</p>
    </div>

    <div class="ld-panel">
      <h3 class="ld-panel__title">Por milar</h3>
      <ul class="ld-milar">
        {porMilar.map((m: any) => (
          <li class="ld-milar__item">
            <span class="ld-milar__rango">{m.rango}</span>
            <span class="ld-milar__val">{m.apariciones}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="ld-panel">
      <h3 class="ld-panel__title">A primera</h3>
      <p class="ld-panel__meta">
        Promedio: <strong class="ld-num">{aPrimera.promedio}</strong>
        &nbsp;·&nbsp;
        Franja 4000–5999: <strong>{formatPct(aPrimera.pct4000a5999)}</strong>
        &nbsp;(esperado: {formatPct(aPrimera.esperado4000a5999)})
      </p>
    </div>

  </section>

  <!-- H. Turista (solo Córdoba) -->
  {turista && (
    <section class="ld-turista container-wide">
      <h2 class="ld-section-title">Quiniela del Turista (22:15)</h2>
      <div class="ld-turista__stats">
        <div class="ld-stat ld-stat--sm">
          <span class="ld-stat__num">{turista.sorteos}</span>
          <span class="ld-stat__label">sorteos</span>
        </div>
        <div class="ld-stat ld-stat--sm">
          <span class="ld-stat__num">{turista.aPrimera.promedio}</span>
          <span class="ld-stat__label">promedio a primera</span>
        </div>
        <div class="ld-stat ld-stat--sm">
          <span class="ld-stat__num">{formatPct(turista.aPrimera.pct4000a5999)}</span>
          <span class="ld-stat__label">franja 4000-5999</span>
        </div>
      </div>

      <div class="ld-turista__top">
        <h3 class="ld-panel__title">Punteros del mes</h3>
        {turistaVisibles.map((grupo) => (
          <div class="ld-turista__grupo">
            <span class="ld-turista__ap">{grupo.apariciones} ap. →</span>
            {grupo.numeros.map((n, ni) => (
              <span class="ld-num">{n}{ni < grupo.numeros.length - 1 ? ', ' : ''}</span>
            ))}
          </div>
        ))}
        {turistaOcultos.map((grupo) => (
          <p class="ld-turista__resto">
            y {grupo.numeros.length} más con {grupo.apariciones} apariciones
          </p>
        ))}
      </div>
    </section>
  )}

  <!-- I. Cierre editorial -->
  {cierre && (
    <section class="ld-cierre container-prose">
      <div set:html={renderProseHTML(cierre)} />
    </section>
  )}

  <!-- J. Pie editorial -->
  <footer class="ld-pie container-wide">
    <p class="ld-pie__firma">Análisis de <strong>Tomás Vera</strong></p>
    <p class="ld-pie__legal">
      SaleHoy es análisis cultural, no predicción.
      La quiniela es un juego de azar regulado.
      Jugá responsable. Ayuda por juego problemático: Sedronar <strong>141</strong>.
    </p>
  </footer>

</div>

<style>
  /* ── Variables de zona ───────────────────────────────────────────────────── */
  .ld-zona {
    background-color: var(--ld-bg);
    color: var(--ld-accent);
    min-height: 100vh;
  }

  /* ── Breadcrumb ─────────────────────────────────────────────────────────── */
  .ld-crumbs {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-lg);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    border-bottom: 1px solid;
    border-color: color-mix(in srgb, var(--ld-accent) 20%, transparent);
  }

  .ld-crumb {
    color: color-mix(in srgb, var(--ld-accent) 60%, transparent);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .ld-crumb:hover { color: var(--ld-accent); }
  .ld-crumb--current { color: var(--ld-accent); }
  .ld-crumb-sep { opacity: 0.4; }

  /* ── Hero ───────────────────────────────────────────────────────────────── */
  .ld-hero {
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid;
    border-color: color-mix(in srgb, var(--ld-accent) 15%, transparent);
  }

  /* ── Ticker ─────────────────────────────────────────────────────────────── */
  .ld-ticker {
    overflow: hidden;
    background: color-mix(in srgb, var(--ld-accent) 8%, transparent);
    border-bottom: 1px solid;
    border-color: color-mix(in srgb, var(--ld-accent) 20%, transparent);
    padding-block: var(--space-xs);
    white-space: nowrap;
  }

  .ld-ticker__track {
    display: inline-flex;
    animation: ldScroll 50s linear infinite;
  }

  .ld-ticker__txt {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    color: color-mix(in srgb, var(--ld-accent) 70%, transparent);
    padding-inline: var(--space-md);
  }

  @keyframes ldScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ld-ticker__track { animation: none; }
  }

  /* ── Hero head ──────────────────────────────────────────────────────────── */
  .ld-hero__head {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-lg);
  }

  .ld-hero__eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.2em;
    color: color-mix(in srgb, var(--ld-accent) 50%, transparent);
    margin: 0 0 var(--space-xs);
  }

  .ld-hero__nombre {
    font-family: var(--font-display);
    font-size: clamp(var(--text-4xl), 8vw, var(--text-7xl));
    font-weight: var(--font-bold);
    line-height: var(--leading-tight);
    color: var(--ld-accent);
    margin: 0 0 var(--space-sm);
    letter-spacing: -0.02em;
  }

  .ld-hero__periodo {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: color-mix(in srgb, var(--ld-accent) 60%, transparent);
    margin: 0;
    letter-spacing: 0.05em;
  }

  /* ── Stats trio ─────────────────────────────────────────────────────────── */
  .ld-hero__stats {
    display: flex;
    gap: var(--space-xl);
    padding-block: var(--space-lg);
    border-top: 1px solid;
    border-color: color-mix(in srgb, var(--ld-accent) 15%, transparent);
    flex-wrap: wrap;
  }

  .ld-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .ld-stat--sm .ld-stat__num {
    font-size: var(--text-xl);
  }

  .ld-stat__num {
    font-family: var(--font-mono);
    font-size: clamp(var(--text-2xl), 4vw, var(--text-4xl));
    font-weight: var(--font-bold);
    color: var(--ld-accent);
    line-height: 1;
  }

  .ld-stat__label {
    font-family: var(--font-body);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--ld-accent) 50%, transparent);
  }

  /* ── Resumen rápido ─────────────────────────────────────────────────────── */
  .ld-resumen {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: var(--space-md);
    padding-block: var(--space-lg);
    border-top: 1px solid;
    border-color: color-mix(in srgb, var(--ld-accent) 15%, transparent);
  }

  .ld-resumen__celda {
    background: color-mix(in srgb, var(--ld-accent) 6%, transparent);
    border: 1px solid;
    border-color: color-mix(in srgb, var(--ld-accent) 20%, transparent);
    border-radius: var(--radius-md);
    padding: var(--space-md);
  }

  .ld-resumen__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    color: color-mix(in srgb, var(--ld-accent) 55%, transparent);
    margin: 0 0 var(--space-xs);
    text-transform: uppercase;
  }

  .ld-resumen__val {
    font-family: var(--font-mono);
    font-size: var(--text-2xl);
    font-weight: var(--font-bold);
    color: var(--ld-accent);
    margin: 0 0 2px;
    line-height: 1;
