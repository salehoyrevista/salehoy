---
interface Props {
  title: string;
  url?: string;
  description?: string;
}

const { title, url, description } = Astro.props;

// URL absoluta para compartir
const shareUrl = url || new URL(Astro.url.pathname, Astro.site).toString();
const shareText = description ? `${title} — ${description}` : title;

const encodedUrl = encodeURIComponent(shareUrl);
const encodedText = encodeURIComponent(shareText);
const encodedTitle = encodeURIComponent(title);

const links = {
  whatsapp: `https://wa.me/?text=${encodedText}%20${encodedUrl}`,
  x: `https://twitter.com/intent/tweet?text=${encodedText}&url=${encodedUrl}`,
  facebook: `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`,
  telegram: `https://t.me/share/url?url=${encodedUrl}&text=${encodedText}`,
  mail: `mailto:?subject=${encodedTitle}&body=${encodedText}%0A%0A${encodedUrl}`,
};
---

<aside class="share">
  <span class="meta-label">Compartir</span>
  <div class="share__buttons">
    <a href={links.whatsapp} target="_blank" rel="noopener" class="share__btn" aria-label="Compartir en WhatsApp" title="WhatsApp">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
      </svg>
    </a>

    <a href={links.x} target="_blank" rel="noopener" class="share__btn" aria-label="Compartir en X" title="X (Twitter)">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>

    <a href={links.facebook} target="_blank" rel="noopener" class="share__btn" aria-label="Compartir en Facebook" title="Facebook">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
        <path d="M9.101 23.691v-7.98H6.627v-3.667h2.474v-1.58c0-4.085 1.848-5.978 5.858-5.978.401 0 .955.042 1.468.103a8.68 8.68 0 011.141.195v3.325a8.623 8.623 0 00-.653-.036 26.805 26.805 0 00-.733-.009c-.707 0-1.259.096-1.675.309a1.686 1.686 0 00-.679.622c-.258.42-.374.995-.374 1.752v1.297h3.919l-.386 2.103-.287 1.564h-3.246v8.245C19.396 23.238 24 18.179 24 12.044c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.628 3.874 10.35 9.101 11.647z"/>
      </svg>
    </a>

    <a href={links.telegram} target="_blank" rel="noopener" class="share__btn" aria-label="Compartir en Telegram" title="Telegram">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="currentColor" aria-hidden="true">
        <path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.48.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/>
      </svg>
    </a>

    <a href={links.mail} class="share__btn" aria-label="Compartir por mail" title="Mail">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="2" y="4" width="20" height="16" rx="2"/>
        <path d="m22 7-10 5L2 7"/>
      </svg>
    </a>

    <button class="share__btn share__btn--copy" data-url={shareUrl} aria-label="Copiar link" title="Copiar link">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
        <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
      </svg>
      <span class="share__feedback" aria-hidden="true">Copiado</span>
    </button>
  </div>
</aside>

<script>
  document.querySelectorAll<HTMLButtonElement>('.share__btn--copy').forEach(btn => {
    btn.addEventListener('click', async () => {
      const url = btn.dataset.url;
      if (!url) return;
      try {
        await navigator.clipboard.writeText(url);
        btn.classList.add('share__btn--copied');
        setTimeout(() => btn.classList.remove('share__btn--copied'), 1800);
      } catch (e) {
        alert('No se pudo copiar el link. Copialo a mano: ' + url);
      }
    });
  });
</script>

<style>
  .share {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
    padding-block: var(--space-xl);
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    margin-block: var(--space-2xl);
  }

  .share__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
    justify-content: center;
  }

  .share__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    border: 1px solid var(--color-line);
    color: var(--color-text-secondary);
    background: transparent;
    cursor: pointer;
    transition: all var(--transition-fast);
    position: relative;
  }

  .share__btn:hover {
    border-color: var(--color-accent-gold);
    color: var(--color-accent-gold);
    transform: translateY(-2px);
  }

  .share__btn:focus-visible {
    outline: 2px solid var(--color-accent-gold);
    outline-offset: 2px;
  }

  .share__feedback {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-accent-gold);
    color: var(--color-bg);
    font-family: var(--font-body);
    font-size: var(--text-xs);
    font-weight: var(--font-medium);
    padding: 4px 10px;
    border-radius: var(--radius-full);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-base);
    white-space: nowrap;
  }

  .share__btn--copied .share__feedback {
    opacity: 1;
  }
</style>
